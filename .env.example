# Database connection string (Neon Postgres or standard PostgreSQL)
DATABASE_URL=postgresql://user:password@host:port/database?sslmode=require

# Google Gemini API key for natural language understanding and responses
GEMINI_API_KEY=your_gemini_api_key_here

# Toggle to determine which WhatsApp provider to use (true = Twilio, false/unset = Meta Graph API)
USE_TWILIO=false

# Twilio Credentials (required if USE_TWILIO=true)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_FROM_NUMBER=whatsapp:+14155238886

# Meta WhatsApp Cloud API credentials (required if USE_TWILIO=false)
META_PHONE_NUMBER_ID=your_meta_phone_number_id_here
META_WHATSAPP_TOKEN=your_meta_whatsapp_token_here

# Password protecting the admin / client dashboard web panel
DASHBOARD_PASSWORD=your_dashboard_password_here
